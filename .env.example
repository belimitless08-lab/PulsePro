# Fyers API Credentials - Copy this file to .env and fill your real values
FYERS_APP_ID=your_fyers_app_id_here
FYERS_SECRET_KEY=your_fyers_secret_key_here

# Redirect URI (used during login)
FYERS_REDIRECT_URI=http://127.0.0.1:8000

# Redis (will be configured later on Railway)
REDIS_URL=redis://localhost:6379/0
